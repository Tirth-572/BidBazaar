{
  "name": "bidbazaar",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"magenta,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node --no-warnings=ExperimentalWarning --env-file=backend/.env --watch backend/src/index.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "start:backend": "node --no-warnings=ExperimentalWarning --env-file=backend/.env backend/src/index.js"
  },
  "devDependencies": {
    "concurrently": "*"
  }
}
